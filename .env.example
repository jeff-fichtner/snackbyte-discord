# Local development environment values. Copy to .env (which is gitignored).
# In production these come from the platform (Cloud Run injects PORT; secrets come
# from Secret Manager). Variable expansion is supported, e.g.:
#   HOST=localhost
#   BASE_URL=http://${HOST}:${PORT}

# Port the server listens on (and the dev proxy targets).
PORT=8080

# Log level for structured (pino) logging: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# --- Discord bot ---
# Bot token from the Discord Developer Portal (Bot tab -> Reset Token). Secret.
DISCORD_BOT_TOKEN=
# Application (client) id from the Developer Portal (General Information).
DISCORD_APP_ID=
# A test guild id for instant guild-scoped slash-command registration in dev.
# Leave blank in production to register commands globally.
DISCORD_DEV_GUILD_ID=

# --- Database (routing store) ---
# PostgreSQL connection string (Supabase: Project Settings -> Database -> Connection string).
DATABASE_URL=

# --- Source signing secrets (referenced by sources.secret_ref) ---
# The value the source signs its webhooks with. The DB row stores the NAME
# "clickup_webhook_secret"; this env var holds the value. Secret.
CLICKUP_WEBHOOK_SECRET=

# --- Discord delivery webhook URLs (referenced by discord_targets.webhook_url_ref) ---
# A Discord channel webhook URL (Channel -> Integrations -> Webhooks). The DB row
# stores the NAME (e.g. "demo_channel_webhook"); this env var holds the URL. Secret.
DEMO_CHANNEL_WEBHOOK=
