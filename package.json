{
  "name": "snackbyte-discord",
  "version": "0.1",
  "private": true,
  "type": "module",
  "description": "snackbyte-discord — a snackbyte app.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "start": "node dist/server/main.js",
    "deploy:commands": "node --import tsx scripts/run-deploy-commands.mjs",
    "migrate": "node scripts/migrate.mjs",
    "lint": "eslint .",
    "format": "prettier --config config/.prettierrc.json --ignore-path config/.prettierignore --write \"**/*.{ts,tsx,js,mjs,json,md,html}\"",
    "format:check": "prettier --config config/.prettierrc.json --ignore-path config/.prettierignore --check \"**/*.{ts,tsx,js,mjs,json,md,html}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:release": "bash scripts/derive-version.test.sh",
    "check:all": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "spec:html": "node scripts/spec-html.mjs"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^27.0.1",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.15",
    "vitest": "^4.1.8"
  }
}
